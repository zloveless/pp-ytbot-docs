---
import '../styles/main.scss';
import { getCollection } from 'astro:content';

const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const versionEntries = (await getCollection('commands'))
  .sort((a, b) => b.data.updatedAt.localeCompare(a.data.updatedAt));

function fmtDate(iso: string) {
  return new Date(iso + 'T00:00:00').toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric',
  });
}

---
<!doctype html>
<html lang="en" data-bs-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter?.title ?? 'ytbot docs — @pseudoposse'}</title>
    <script is:inline>
      // Apply saved preference before first paint to prevent FOUC
      (function () {
        var saved = localStorage.getItem('ytbot-theme');
        var preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-bs-theme', saved ?? preferred);
      })();
    </script>
  </head>
  <body>
    <nav class="navbar navbar-expand-md bg-body-tertiary border-bottom mb-4">
      <div class="container">
        <a class="navbar-brand fw-bold" href={base}>@pseudoposse Viewer Bot</a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#nav-collapse"
          aria-controls="nav-collapse"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav-collapse">
          <ul class="navbar-nav me-auto mb-2 mb-md-0">
            <li class="nav-item"><a class="nav-link" href={base}>Home</a></li>
            <li class="nav-item"><a class="nav-link" href={`${base}/how-it-works`}>How It Works</a></li>
            <li class="nav-item"><a class="nav-link" href={`${base}/commands`}>Commands</a></li>
            <li class="nav-item"><a class="nav-link" href={`${base}/commands/spawns`}>Spawns</a></li>
          </ul>
          <div class="d-flex align-items-center gap-2">
            <select id="version-select" class="form-select form-select-sm" style="width: auto;" aria-label="Command version">
              {versionEntries.map(v => (
                <option value={v.id}>{v.data.label} — {fmtDate(v.data.updatedAt)}</option>
              ))}
            </select>
            <a
              href="https://youtube.com/@pseudoposse"
              class="btn btn-sm btn-outline-danger"
              target="_blank"
              rel="noopener noreferrer"
            >▶ Watch Live</a>
            <button id="theme-toggle" class="btn btn-outline-secondary btn-sm" aria-label="Toggle color theme" title="Toggle light/dark mode">
              ☀️
            </button>
          </div>
        </div>
      </div>
    </nav>

    <main class="container pb-5">
      <slot />
    </main>

    <footer class="border-top mt-5 py-3 bg-body-tertiary">
      <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2 small text-muted">
        <span>
          ytbot — 7 Days to Die viewer commands for
          <a href="https://youtube.com/@pseudoposse" target="_blank" rel="noopener noreferrer">@pseudoposse</a>
        </span>
        <span>
          Docs by <a href="https://github.com/zloveless" target="_blank" rel="noopener noreferrer">Genesis</a>
          &nbsp;·&nbsp;
          <a href="https://github.com/zloveless/pp-ytbot-docs" target="_blank" rel="noopener noreferrer">Source on GitHub</a>
        </span>
      </div>
    </footer>

    <script>
      import 'bootstrap/dist/js/bootstrap.esm.js';

      const toggle = document.getElementById('theme-toggle') as HTMLButtonElement;

      function getTheme() {
        return document.documentElement.getAttribute('data-bs-theme') as 'light' | 'dark';
      }

      function applyTheme(theme: 'light' | 'dark') {
        document.documentElement.setAttribute('data-bs-theme', theme);
        localStorage.setItem('ytbot-theme', theme);
        toggle.textContent = theme === 'dark' ? '☀️' : '🌙';
      }

      applyTheme(getTheme());

      toggle.addEventListener('click', () => {
        applyTheme(getTheme() === 'dark' ? 'light' : 'dark');
      });

      const versionSelect = document.getElementById('version-select') as HTMLSelectElement | null;

      function applyVersionFilter(ver: string) {
        document.querySelectorAll<HTMLElement>('[data-ver]').forEach(row => {
          row.style.display = row.dataset.ver === ver ? '' : 'none';
        });
      }

      if (versionSelect) {
        versionSelect.addEventListener('change', () => applyVersionFilter(versionSelect.value));
        applyVersionFilter(versionSelect.value);
      }
    </script>
  </body>
</html>
